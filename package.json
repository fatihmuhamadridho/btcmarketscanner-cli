{
  "name": "btcmarketscanner-cli",
  "version": "0.0.1",
  "description": "",
  "private": true,
  "type": "module",
  "bin": {
    "ai-agent": "./src/index.tsx"
  },
  "scripts": {
    "dev": "pnpm run deps:dev && pnpm run deps:sync && node --watch --watch-preserve-output --import tsx src/index.tsx",
    "start": "tsx src/index.tsx",
    "prepare": "husky",
    "deps:dev": "node ./scripts/switch-core-dependency.mjs workspace",
    "deps:prod": "node ./scripts/switch-core-dependency.mjs github",
    "deps:sync": "CI=1 pnpm install --force"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "btcmarketscanner-core": "workspace:*",
    "ink": "^6.8.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
