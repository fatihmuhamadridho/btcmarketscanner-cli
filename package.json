{
  "name": "btcmarketscanner-cli",
  "version": "0.0.1",
  "description": "",
  "private": true,
  "type": "module",
  "bin": {
    "ai-agent": "./src/index.tsx"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "dev": "NODE_ENV=development node --watch --watch-preserve-output --import tsx --import ./src/env.ts src/index.tsx",
    "start": "NODE_ENV=production node --import ./dist/env.js dist/index.js",
    "prepare": "husky",
    "deps:dev": "node ./scripts/switch-core-dependency.mjs workspace",
    "deps:prod": "node ./scripts/switch-core-dependency.mjs github",
    "deps:sync": "CI=1 pnpm install --force"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "axios": "^1.15.0",
    "btcmarketscanner-core": "github:fatihmuhamadridho/btcmarketscanner-core#master",
    "dotenv": "^17.4.1",
    "ink": "^6.8.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
