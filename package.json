{
  "name": "btcmarketscanner-cli",
  "version": "0.0.1",
  "description": "",
  "private": true,
  "type": "module",
  "bin": {
    "ai-agent": "./src/index.tsx"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "dev": "NODE_ENV=development node ./scripts/dev.mjs",
    "start": "NODE_ENV=production node dist/index.js",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md,cjs,mjs}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md,cjs,mjs}\" \"*.{json,md}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "deps:dev": "node ./scripts/switch-core-dependency.mjs workspace",
    "deps:prod": "node ./scripts/switch-core-dependency.mjs github",
    "deps:sync": "CI=1 pnpm install --force",
    "bot": "node ./scripts/command-executor.mjs bot",
    "watch": "node ./scripts/command-executor.mjs watch",
    "revalidate": "node ./scripts/command-executor.mjs revalidate",
    "telegram-bot:dev": "NODE_ENV=development tsx src/scripts/telegram-bot.ts",
    "telegram-bot:prod": "NODE_ENV=production node dist/scripts/telegram-bot.js",
    "test:telegram-commands": "tsx scripts/test-telegram-commands.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "axios": "^1.15.0",
    "btcmarketscanner-core": "github:fatihmuhamadridho/btcmarketscanner-core#master",
    "dotenv": "^17.4.1",
    "ink": "^6.8.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
